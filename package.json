{
  "name": "@donotdev/oauth",
  "version": "0.1.42",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "OAuth utilities for DoNotDev",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "dev": "tsc --noEmit --watch --listFiles false --listEmittedFiles false",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "type-check": "bunx tsc --noEmit"
  },
  "dependencies": {
    "valibot": "^1.2.0"
  },
  "peerDependencies": {
    "@donotdev/components": "^0.1.42",
    "@donotdev/core": "^0.1.42",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/donotdev/oauth.git"
  },
  "keywords": [
    "donotdev",
    "dndev",
    "oauth",
    "authentication",
    "social-login",
    "firebase",
    "react",
    "typescript"
  ],
  "devDependencies": {
    "@donotdev/components": "workspace:*",
    "@donotdev/core": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "peerDependenciesMeta": {}
}